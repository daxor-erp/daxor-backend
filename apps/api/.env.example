NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/daxor
MONGO_DEBUG=false
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d
OBSERVABILITY_ENABLED=false
SERVICE_NAME=daxor-api
UPLOAD_DIR=uploads

# SMTP (Nodemailer) — required to email quotations from Send Quotations
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@yourcompany.com
