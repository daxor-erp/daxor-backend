{
	"name": "api",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"clean": "rm -rf dist",
		"format": "biome format . --write",
		"lint": "tsc --noEmit && biome lint .",
		"lint:fix": "biome lint . --write && biome format . --write",
		"codegen": "graphql-codegen",
		"build": "rm -rf dist && node esbuild.config.js",
		"dev": "NODE_ENV=development nodemon --exec \"node -r esbuild-register ./src/index.ts\" -e .ts",
		"prod": "NODE_ENV=production nodemon --exec \"node -r esbuild-register ./src/index.ts\" -e .ts"
	},
	"dependencies": {
		"@apollo/server": "^4.12.0",
		"@graphql-tools/load-files": "^7.0.1",
		"@graphql-tools/merge": "^9.1.1",
		"@graphql-tools/schema": "^10.0.25",
		"@repo/db": "workspace:*",
		"@repo/errors": "workspace:*",
		"@repo/observability": "workspace:*",
		"bcryptjs": "^3.0.2",
		"compression": "^1.8.0",
		"cors": "^2.8.5",
		"dataloader": "^2.2.3",
		"dotenv": "^16.5.0",
		"express": "^4.21.2",
		"express-rate-limit": "^7.5.0",
		"graphql": "^16.10.0",
		"graphql-depth-limit": "^1.1.0",
		"graphql-middleware": "^6.1.35",
		"graphql-scalars": "^1.24.2",
		"graphql-shield": "^7.6.5",
		"graphql-ws": "^6.0.7",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.2",
		"mongodb": "^6.20.0",
		"mongoose": "^8.13.2",
		"nodemailer": "^8.0.3",
		"puppeteer": "^24.7.1",
		"reflect-metadata": "^0.2.2",
		"tsyringe": "^4.10.0",
		"ws": "^8.19.0",
		"zod": "^3.24.3"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^5.0.5",
		"@graphql-codegen/typescript": "^4.1.6",
		"@graphql-codegen/typescript-resolvers": "4.4.1",
		"@repo/biome-config": "workspace:*",
		"@types/compression": "^1.7.5",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.9",
		"@types/node": "^20.17.30",
		"@types/nodemailer": "^7.0.11",
		"@types/ws": "^8.18.1",
		"biome": "^0.3.3",
		"esbuild": "^0.25.8",
		"esbuild-register": "^3.6.0",
		"nodemon": "^3.1.10",
		"typescript": "^5.8.3"
	}
}
